<div class="card">
    <div class="card-header">
        <h5>Building Blocks</h5>
    </div>
    <div class="card-body">
        <div class="row">
            <!-- Directive Building Block -->
            <div class="col-md-6 mb-3">
                <div class="building-block-type directive-block"
                     draggable="true"
                     id="directive-block">
                    <div class="building-block-content">
                        <i class="bi bi-hash"></i>
                        <span>Directive</span>
                        <small class="text-muted">#showtooltip, etc.</small>
                    </div>
                </div>
            </div>

            <!-- Command Building Block -->
            <div class="col-md-6 mb-3">
                <div class="building-block-type command-block"
                     draggable="true"
                     id="command-block">
                    <div class="building-block-content">
                        <i class="bi bi-slash"></i>
                        <span>Command</span>
                        <small class="text-muted">/cast, /use, etc.</small>
                    </div>
                </div>
            </div>

            <!-- Conditional Group Building Block -->
            <div class="col-md-6 mb-3">
                <div class="building-block-type conditional-block"
                     draggable="true"
                     id="conditional-block">
                    <div class="building-block-content">
                        <i class="bi bi-brackets"></i>
                        <span>Conditional Group</span>
                        <small class="text-muted">[combat], [mod:alt], etc.</small>
                    </div>
                </div>
            </div>

            <!-- Argument Building Block -->
            <div class="col-md-6 mb-3">
                <div class="building-block-type argument-block"
                     draggable="true"
                     id="argument-block">
                    <div class="building-block-content">
                        <i class="bi bi-text-paragraph"></i>
                        <span>Argument</span>
                        <small class="text-muted">Spell name, target, etc.</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-3">
            <small class="text-muted">
                <i class="bi bi-info-circle"></i>
                Drag building blocks to macro lines, then click to configure them.
            </small>
        </div>
    </div>
</div>
